# ============================================================================
# Quest Start My Day — Environment Variables
# ============================================================================
# Copy this file to .env for local development, or paste these values into
# Railway's "Variables" tab for deployment.

# --- REQUIRED ---

# PostgreSQL connection string.
# On Railway: set to ${{ Postgres.DATABASE_URL }}
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Port the server listens on. Railway sets this automatically.
PORT=8080

# Frontend base path. Use "/" when serving the frontend from the same domain
# as the API (recommended on Railway).
BASE_PATH=/

# Node environment.
NODE_ENV=production

# Path to the built frontend files. Makes the API server also serve the
# React app at the root URL.
# On Railway this should be: /app/artifacts/dist
STATIC_DIR=/app/artifacts/dist

# --- SECURITY (Phase 1) ---

# Comma-separated list of allowed CORS origins. When unset, CORS is
# disabled (same-origin only). Example:
#   CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=

# Rate limiter for /api routes. Defaults: 300 requests per 15 minutes per IP.
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW_MS=900000

# --- AUTH (Phase 2) ---

# Clerk secret key for backend token verification. When unset the API runs
# in "owner mode" — every request is auto-scoped to OWNER_USER_ID below.
CLERK_SECRET_KEY=

# Clerk publishable key used by the React app. Exposed via
# import.meta.env.VITE_CLERK_PUBLISHABLE_KEY. When unset the frontend
# renders without an auth gate (matches backend owner mode).
VITE_CLERK_PUBLISHABLE_KEY=

# Owner user ID used in owner mode and for the backfill migration. All
# pre-Clerk data is assigned to this user. Once Clerk is wired up, run:
#   UPDATE users SET id = '<real_clerk_user_id>' WHERE id = 'owner';
# to remap (the FK ON UPDATE CASCADE keeps everything in sync).
OWNER_USER_ID=owner
OWNER_EMAIL=info@asterandspruceliving.ca

# --- BILLING (Phase 6 — not used yet) ---

# Stripe API keys for subscription billing.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# --- OBSERVABILITY (Phase 7 — not used yet) ---

# Sentry DSN for error reporting.
SENTRY_DSN=

# PostHog project key for product analytics.
POSTHOG_KEY=
POSTHOG_HOST=
