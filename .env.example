# ============================================================================
# Quest Start My Day — Environment Variables
# ============================================================================
# Copy this file to .env for local development, or paste these values into
# Railway's "Variables" tab for deployment.

# --- REQUIRED ---

# PostgreSQL connection string.
# On Railway: set to ${{ Postgres.DATABASE_URL }}
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Port the server listens on. Railway sets this automatically.
PORT=8080

# Frontend base path. Use "/" when serving the frontend from the same domain
# as the API (recommended on Railway).
BASE_PATH=/

# Node environment.
NODE_ENV=production

# Path to the built frontend files. Makes the API server also serve the
# React app at the root URL.
# On Railway this should be: /app/artifacts/dist
STATIC_DIR=/app/artifacts/dist

# --- SECURITY (Phase 1) ---

# Comma-separated list of allowed CORS origins. When unset, CORS is
# disabled (same-origin only). Example:
#   CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=

# Rate limiter for /api routes. Defaults: 300 requests per 15 minutes per IP.
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW_MS=900000

# --- AUTH (Phase 2) ---

# Clerk secret key for backend token verification. When unset the API runs
# in "owner mode" — every request is auto-scoped to OWNER_USER_ID below.
CLERK_SECRET_KEY=

# Clerk publishable key used by the React app. Exposed via
# import.meta.env.VITE_CLERK_PUBLISHABLE_KEY. When unset the frontend
# renders without an auth gate (matches backend owner mode).
VITE_CLERK_PUBLISHABLE_KEY=

# Owner user ID used in owner mode and for the backfill migration. All
# pre-Clerk data is assigned to this user. Once Clerk is wired up, run:
#   UPDATE users SET id = '<real_clerk_user_id>' WHERE id = 'owner';
# to remap (the FK ON UPDATE CASCADE keeps everything in sync).
OWNER_USER_ID=owner
OWNER_EMAIL=info@asterandspruceliving.ca

# --- BILLING (Phase 7) ---

# Stripe is OPT-IN: leave STRIPE_SECRET_KEY unset and billing UI is hidden,
# all users are treated as Pro (no plan gating). When set, the /billing page
# is enabled, plan limits apply to free users, and Stripe Checkout / Billing
# Portal flows become available.

# Stripe secret key used by the backend (server-side). When unset the
# /api/billing/* routes return a friendly error and plan gating is bypassed.
STRIPE_SECRET_KEY=

# Webhook signing secret. Required to verify the
# /api/billing/webhook payloads sent by Stripe.
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs for the Pro plan (monthly + yearly). These are the IDs
# from your Stripe dashboard (e.g. "price_..."). Defaults are inert; set
# real values once products are configured in Stripe.
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=

# Publishable key used by the React frontend. Exposed via
# import.meta.env.VITE_STRIPE_PUBLISHABLE_KEY. Leave unset to hide the
# /billing page entirely (matches backend owner / Stripe-not-configured mode).
VITE_STRIPE_PUBLISHABLE_KEY=

# URL Stripe redirects to after the customer leaves the Billing Portal.
# Defaults to "/profile" when unset.
BILLING_PORTAL_RETURN_URL=

# --- OBSERVABILITY (Phase 6) ---

# All observability is OPT-IN: leave any of these unset and the app runs
# identically to before — no Sentry init, no PostHog requests, no warnings.
# Same pattern as the Phase 2 Clerk fallback.

# Sentry DSN for backend error reporting (capturing unhandled errors from the
# express error middleware).
SENTRY_DSN=
# Optional: defaults to NODE_ENV. Used as the Sentry environment tag.
SENTRY_ENVIRONMENT=

# Sentry DSN for the React frontend. Exposed to the bundle via
# import.meta.env.VITE_SENTRY_DSN. Leave blank to disable.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=

# PostHog project key for product analytics. Exposed via
# import.meta.env.VITE_POSTHOG_KEY. Leave blank to disable.
VITE_POSTHOG_KEY=
# Optional override of the PostHog ingestion host.
VITE_POSTHOG_HOST=
